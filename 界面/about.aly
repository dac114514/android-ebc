                    {
                      LinearLayout;
                      layout_width="match_parent";
                      layout_height="match_parent";
                      orientation="vertical";
                      {
                        TextView;
                        layout_width="match_parent";
                        paddingTop="15sp";
                        padding="10dp";
                        paddingBottom="0dp";
                        textSize="17sp";
                        text="QQ群聊";
                        paddingLeft="0dp";
                        textColor="0xFFD7D7D7";
                      };
                      {
                        TextView;
                        layout_width="match_parent";
                        padding="10dp";
                        paddingTop="0dp";
                        textSize="15sp";
                        text="加入官方交流群组";
                        paddingLeft="0dp";
                        textColor="0xFFD0D0D0";
                      };
                    };
                  };
                };
              };
            };
            {
              CardView;
              CardBackgroundColor="#2B2B2B";
              layout_marginTop="0dp";
              layout_height="wrap_content";
              CardElevation="0dp";
              radius="10dp";
              layout_width="match_parent";
              paddingBottom="20dp";
              layout_margin="20dp";
              {
                LinearLayout;
                layout_width="match_parent";
                layout_height="wrap_content";
                orientation="vertical";
                {
                  TextView;
                  layout_marginTop="10dp";
                  layout_margin="10dp";
                  textSize="17sp";
                  text="开发者";
                  id="card2";
                  textColor="#4DB04E";
                };
                {
                  LinearLayout;
                  layout_width="match_parent";
                  layout_height="67dp";
                  gravity="left|center";
                  {
                    CardView;
                    layout_marginLeft="20dp";
                    layout_height="wrap_content";
                    CardElevation="0dp";
                    radius="24dp";
                    layout_marginRight="5dp";
                    layout_width="wrap_content";
                    {
                      ImageView;
                      layout_width="50dp";
                      src="icon.png";
                      layout_height="50dp";
                      scaleType="centerCrop";
                    };
                  };
                  {
                    LinearLayout;
                    layout_width="match_parent";
                    layout_height="match_parent";
                    orientation="vertical";
                    {
                      TextView;
                      layout_weight="1";
                      paddingTop="10dp";
                      padding="3dp";
                      paddingBottom="0dp";
                      textSize="18sp";
                      text="极客";
                      layout_width="match_parent";
                      textColor="0xFFC6DEC5";
                    };
                    {
                      TextView;
                      id="sub";
                      layout_weight="1";
                      padding="3dp";
                      paddingTop="0dp";
                      textSize="14sp";
                      text="开发者";
                      layout_width="match_parent";
                      textColor="0xFFBBBBBB";
                    };
                  };
                };
                {
                  LinearLayout;
                  layout_width="match_parent";
                  layout_height="10dp";
                };
              };
            };
            {
              CardView;
              CardBackgroundColor="#2B2B2B";
