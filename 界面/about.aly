              layout_marginTop="0dp";
              layout_width="match_parent";
              layout_margin="20dp";
              {
                ScrollView;
                layout_width="match_parent";
                layout_height="wrap_content";
                {
                  LinearLayout;
                  layout_width="match_parent";
                  layout_height="wrap_content";
                  orientation="vertical";
                  {
                    TextView;
                    padding="10dp";
